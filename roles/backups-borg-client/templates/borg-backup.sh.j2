#!/usr/bin/env bash
# Borg offsite backup for {{ inventory_hostname }}
# Generated by Ansible - do not edit manually
set -euo pipefail

export BORG_REPO="ssh://{{ borg_storage_box_user }}@{{ borg_storage_box_host }}:{{ borg_storage_box_port }}/{{ borg_repo_path }}"
export BORG_PASSPHRASE
BORG_PASSPHRASE="$(<"{{ borg_passphrase_file }}")"
export BORG_RSH="ssh -i {{ borg_ssh_key_path }} -o BatchMode=yes -o StrictHostKeyChecking=yes"

{% set _backup_datasets = (zfs | default({}) | zfs_datasets_with_policy) | selectattr('policy', 'in', ['high', 'critical']) | list %}
# Datasets: policy high or critical (rendered at deploy time by Ansible)
DATASETS=(
{% for ds in _backup_datasets %}
  {{ ds.dataset | quote }}
{% endfor %}
)

# Parents that require runtime child discovery (e.g. Docker ZFS volumes)
DISCOVER_PARENTS=(
{% for ds in _backup_datasets if ds.get('snapshots_discover_children', false) %}
  {{ ds.dataset | quote }}
{% endfor %}
)

collect_paths() {
    local -A seen=()

    for ds in "${DATASETS[@]}"; do
        local mp
        mp=$(zfs get -H -o value mountpoint "$ds" 2>/dev/null) || continue
        [[ "$mp" == "none" || "$mp" == "-" || "$mp" == "legacy" ]] && continue
        [[ -d "$mp" ]] || continue
        [[ -v seen["$mp"] ]] && continue
        seen["$mp"]=1
        echo "$mp"
    done

    if [[ ${#DISCOVER_PARENTS[@]} -gt 0 ]]; then
        for parent in "${DISCOVER_PARENTS[@]}"; do
            while IFS= read -r child; do
                [[ "$child" == "$parent" ]] && continue
                local mp
                mp=$(zfs get -H -o value mountpoint "$child" 2>/dev/null) || continue
                [[ "$mp" == "none" || "$mp" == "-" || "$mp" == "legacy" ]] && continue
                [[ -d "$mp" ]] || continue
                [[ -v seen["$mp"] ]] && continue
                seen["$mp"]=1
                echo "$mp"
            done < <(zfs list -H -o name -r "$parent" 2>/dev/null)
        done
    fi
}

if [[ ${#DATASETS[@]} -eq 0 ]]; then
    echo "No datasets configured for backup (policy: high or critical)" >&2
    exit 0
fi

# Initialize repository on first run
if ! borg info >/dev/null 2>&1; then
    borg_err=$(borg info 2>&1 || true)
    if ! echo "$borg_err" | grep -qi "does not exist"; then
        echo "error: cannot access borg repository: $borg_err" >&2
        exit 2
    fi
    echo "Initializing Borg repository at ${BORG_REPO}..."
    borg init --encryption=repokey-blake2
fi

mapfile -t BACKUP_PATHS < <(collect_paths)

if [[ ${#BACKUP_PATHS[@]} -eq 0 ]]; then
    echo "error: no mountable ZFS datasets found" >&2
    exit 1
fi

ARCHIVE="{{ inventory_hostname }}-$(date +%Y-%m-%dT%H:%M:%S)"

echo "Creating archive ${ARCHIVE}"
printf '  %s\n' "${BACKUP_PATHS[@]}"

borg create \
    --verbose \
    --stats \
    --show-rc \
    --compression lz4 \
    --exclude-caches \
    "::${ARCHIVE}" \
    "${BACKUP_PATHS[@]}"

borg prune \
    --verbose \
    --show-rc \
    --keep-daily {{ borg_keep_daily }} \
    --keep-weekly {{ borg_keep_weekly }} \
    --keep-monthly {{ borg_keep_monthly }} \
    --keep-yearly {{ borg_keep_yearly }}

borg compact 2>/dev/null || true
