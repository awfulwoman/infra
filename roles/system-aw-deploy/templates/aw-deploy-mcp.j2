#!{{ system_aw_deploy_venv_dir }}/bin/python3
"""Stdio MCP server: thin wrapper around the aw-deploy CLI."""
import asyncio
import os
from pathlib import Path

from mcp.server import Server
from mcp.server.stdio import stdio_server
from mcp import types

_AW_DEPLOY_CANDIDATES = [
    Path("/usr/local/bin/aw-deploy"),
    Path.home() / ".local/bin/aw-deploy",
]
AW_DEPLOY = os.environ.get(
    "AW_DEPLOY_BIN",
    str(next((p for p in _AW_DEPLOY_CANDIDATES if p.exists()), _AW_DEPLOY_CANDIDATES[0])),
)
STATE_DIR = Path(os.environ.get("AW_STATE_DIR", Path.home() / ".local/state/aw-deploy"))
RUNS_DIR = STATE_DIR / "runs"

server = Server("aw-deploy")


@server.list_tools()
async def list_tools():
    return [
        types.Tool(
            name="run_playbook",
            description=(
                "Run an Ansible playbook from ~/Code/awfulwoman/infra against any inventory host. "
                "Prefer this over running ansible-playbook directly — it prevents concurrent deploys and writes run logs. "
                "Use 'list_playbooks' first to see valid paths. "
                "Example: 'playbooks/hosts/apple-macmini-m4-16gb-malcolm/compositions.yaml'"
            ),
            inputSchema={
                "type": "object",
                "required": ["playbook"],
                "properties": {
                    "playbook": {
                        "type": "string",
                        "description": "Playbook path relative to infra repo root",
                    },
                    "limit": {
                        "type": "string",
                        "description": "Limit to a specific Ansible host or group",
                    },
                    "tags": {
                        "type": "string",
                        "description": "Comma-separated Ansible tags to run",
                    },
                    "extra_vars": {
                        "type": "array",
                        "items": {"type": "string"},
                        "description": "Extra variables as KEY=VALUE strings",
                    },
                    "check": {
                        "type": "boolean",
                        "description": "Dry run: passes --check to ansible-playbook, no changes made",
                    },
                },
            },
        ),
        types.Tool(
            name="list_playbooks",
            description="List all available playbooks in the infra repo.",
            inputSchema={"type": "object", "properties": {}},
        ),
        types.Tool(
            name="list_hosts",
            description="List Ansible inventory hosts and groups.",
            inputSchema={"type": "object", "properties": {}},
        ),
        types.Tool(
            name="find_repo",
            description=(
                "Given a GitHub repo URL (any format: HTTPS, SSH, with/without .git), find the Ansible roles "
                "and playbooks in the infra repo that deploy it, and show the exact aw-deploy command to use. "
                "Call this first when asked to deploy a repo you don't know the playbook path for."
            ),
            inputSchema={
                "type": "object",
                "required": ["url"],
                "properties": {
                    "url": {
                        "type": "string",
                        "description": "GitHub repo URL, e.g. git@github.com:awfulwoman/gateway.git or https://github.com/awfulwoman/gateway",
                    },
                },
            },
        ),
        types.Tool(
            name="last_run",
            description="Show the log from the most recent aw-deploy run, optionally filtered by playbook name fragment.",
            inputSchema={
                "type": "object",
                "properties": {
                    "playbook": {
                        "type": "string",
                        "description": "Optional fragment to filter logs by playbook name",
                    },
                },
            },
        ),
    ]


@server.call_tool()
async def call_tool(name: str, arguments: dict):
    arguments = arguments or {}

    if name == "run_playbook":
        cmd = [AW_DEPLOY, "run", arguments["playbook"]]
        if arguments.get("limit"):
            cmd += ["--limit", arguments["limit"]]
        if arguments.get("tags"):
            cmd += ["--tags", arguments["tags"]]
        for ev in arguments.get("extra_vars") or []:
            cmd += ["--extra-vars", ev]
        if arguments.get("check"):
            cmd += ["--check"]
        try:
            proc = await asyncio.create_subprocess_exec(
                *cmd,
                stdout=asyncio.subprocess.PIPE,
                stderr=asyncio.subprocess.STDOUT,
            )
            stdout, _ = await proc.communicate()
            output = stdout.decode(errors="replace")
            if proc.returncode != 0:
                return [types.TextContent(type="text", text=f"FAILED (exit {proc.returncode}):\n{output}")]
            return [types.TextContent(type="text", text=output)]
        except FileNotFoundError:
            return [types.TextContent(type="text", text=f"FAILED: aw-deploy binary not found at {AW_DEPLOY}")]

    if name == "list_playbooks":
        try:
            proc = await asyncio.create_subprocess_exec(
                AW_DEPLOY, "list",
                stdout=asyncio.subprocess.PIPE,
                stderr=asyncio.subprocess.PIPE,
            )
            stdout, stderr = await proc.communicate()
            output = stdout.decode(errors="replace") or stderr.decode(errors="replace")
            if proc.returncode != 0:
                return [types.TextContent(type="text", text=f"FAILED (exit {proc.returncode}):\n{output}")]
            return [types.TextContent(type="text", text=output)]
        except FileNotFoundError:
            return [types.TextContent(type="text", text=f"FAILED: aw-deploy binary not found at {AW_DEPLOY}")]

    if name == "list_hosts":
        try:
            proc = await asyncio.create_subprocess_exec(
                AW_DEPLOY, "hosts",
                stdout=asyncio.subprocess.PIPE,
                stderr=asyncio.subprocess.PIPE,
            )
            stdout, stderr = await proc.communicate()
            output = stdout.decode(errors="replace") or stderr.decode(errors="replace")
            if proc.returncode != 0:
                return [types.TextContent(type="text", text=f"FAILED (exit {proc.returncode}):\n{output}")]
            return [types.TextContent(type="text", text=output)]
        except FileNotFoundError:
            return [types.TextContent(type="text", text=f"FAILED: aw-deploy binary not found at {AW_DEPLOY}")]

    if name == "find_repo":
        try:
            proc = await asyncio.create_subprocess_exec(
                AW_DEPLOY, "repo", arguments["url"],
                stdout=asyncio.subprocess.PIPE,
                stderr=asyncio.subprocess.PIPE,
            )
            stdout, stderr = await proc.communicate()
            output = stdout.decode(errors="replace") or stderr.decode(errors="replace")
            if proc.returncode != 0:
                return [types.TextContent(type="text", text=f"FAILED (exit {proc.returncode}):\n{output}")]
            return [types.TextContent(type="text", text=output)]
        except FileNotFoundError:
            return [types.TextContent(type="text", text=f"FAILED: aw-deploy binary not found at {AW_DEPLOY}")]

    if name == "last_run":
        if not RUNS_DIR.exists():
            return [types.TextContent(type="text", text="No runs found.")]
        fragment = arguments.get("playbook", "")
        pattern = f"*{fragment}*.log" if fragment else "*.log"
        runs = sorted(RUNS_DIR.glob(pattern))
        if not runs:
            return [types.TextContent(type="text", text="No matching runs found.")]
        try:
            content = runs[-1].read_text(errors="replace")
        except OSError as e:
            return [types.TextContent(type="text", text=f"Could not read log: {e}")]
        return [types.TextContent(type="text", text=f"{runs[-1].name}:\n\n{content}")]

    return [types.TextContent(type="text", text=f"Unknown tool: {name}")]


async def main():
    async with stdio_server() as (read_stream, write_stream):
        await server.run(read_stream, write_stream, server.create_initialization_options())


if __name__ == "__main__":
    asyncio.run(main())
