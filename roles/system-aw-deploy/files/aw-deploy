#!/usr/bin/env python3
"""Run Ansible playbooks from the infra repo."""
import argparse
import fcntl
import os
import re
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

INFRA_DIR = Path(os.environ.get("AW_INFRA_DIR", Path.home() / "Code/awfulwoman/infra"))
STATE_DIR = Path(os.environ.get("AW_STATE_DIR", Path.home() / ".local/state/aw-deploy"))
RUNS_DIR = STATE_DIR / "runs"
LOCK_FILE = STATE_DIR / "run.lock"
MAX_RUNS = 30

# Ensure ansible tools and Homebrew are available in subprocesses. The infra
# venv bin is first so its ansible-playbook takes precedence on machines where
# ansible lives there (e.g. the laptop) rather than in Homebrew.
_EXTRA_PATHS = [str(INFRA_DIR / ".venv/bin"), "/opt/homebrew/bin", "/usr/local/bin"]
_current_path = os.environ.get("PATH", "")
_path_parts = _current_path.split(":")
for _p in reversed(_EXTRA_PATHS):
    if _p not in _path_parts:
        _path_parts.insert(0, _p)
os.environ["PATH"] = ":".join(_path_parts)


def _ensure_dirs():
    RUNS_DIR.mkdir(parents=True, exist_ok=True)


def _prune_runs():
    runs = sorted(RUNS_DIR.glob("*.log"))
    for old in runs[:-MAX_RUNS]:
        old.unlink()


def cmd_run(args):
    playbook_path = INFRA_DIR / args.playbook
    if not playbook_path.exists():
        print(f"error: playbook not found: {playbook_path}", file=sys.stderr)
        sys.exit(65)

    cmd = ["ansible-playbook", str(playbook_path)]
    if args.limit:
        cmd += ["--limit", args.limit]
    if args.tags:
        cmd += ["--tags", args.tags]
    for kv in args.extra_vars or []:
        cmd += ["--extra-vars", kv]
    if args.check:
        cmd += ["--check"]

    _ensure_dirs()

    lock_fd = open(LOCK_FILE, "w")
    try:
        fcntl.flock(lock_fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except BlockingIOError:
        lock_fd.close()
        print("error: another aw-deploy run is in progress", file=sys.stderr)
        sys.exit(64)

    ts = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%S")
    slug = args.playbook.replace("/", "-").removesuffix(".yaml")
    log_path = RUNS_DIR / f"{ts}-{slug}.log"

    try:
        with open(log_path, "w") as log_fh:
            proc = subprocess.Popen(
                cmd,
                cwd=str(INFRA_DIR),
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
            )
            for line in proc.stdout:
                sys.stdout.buffer.write(line)
                sys.stdout.buffer.flush()
                log_fh.buffer.write(line)
            proc.wait()
        _prune_runs()
        exit_code = proc.returncode
    finally:
        fcntl.flock(lock_fd, fcntl.LOCK_UN)
        lock_fd.close()

    sys.exit(exit_code)


def cmd_list(args):
    playbooks_dir = INFRA_DIR / "playbooks"
    if not playbooks_dir.exists():
        print(f"error: playbooks dir not found: {playbooks_dir}", file=sys.stderr)
        sys.exit(65)
    for p in sorted(playbooks_dir.rglob("*.yaml")):
        print(str(p.relative_to(INFRA_DIR)))


def cmd_hosts(args):
    result = subprocess.run(
        ["ansible-inventory", "--graph"],
        cwd=str(INFRA_DIR),
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        print(result.stderr, file=sys.stderr)
        sys.exit(result.returncode)
    print(result.stdout)


def cmd_logs(args):
    _ensure_dirs()
    runs = sorted(RUNS_DIR.glob("*.log"))
    for log in runs[-args.tail:]:
        print(f"\n=== {log.name} ===")
        print(log.read_text())


def _parse_github_slug(url: str) -> str:
    """Return 'org/repo' from any GitHub URL format."""
    url = url.strip().rstrip("/")
    if url.endswith(".git"):
        url = url[:-4]
    m = re.match(r"git@github\.com:([^/]+/[^/]+)$", url)
    if m:
        return m.group(1)
    m = re.match(r"(?:https?://)?github\.com/([^/]+/[^/]+)$", url)
    if m:
        return m.group(1)
    if re.match(r"^[^/@:]+/[^/]+$", url):
        return url
    raise ValueError(f"cannot parse as GitHub URL: {url!r}")


def _find_playbooks_for_role(role_name: str) -> list:
    """Return [(playbook_rel_path, [tags])] for playbooks that include role_name."""
    results = []
    for pb in sorted((INFRA_DIR / "playbooks").rglob("*.yaml")):
        lines = pb.read_text(errors="replace").splitlines()
        for i, line in enumerate(lines):
            if re.search(rf"\brole:\s+{re.escape(role_name)}\b", line):
                tags = []
                for j in range(i + 1, min(i + 6, len(lines))):
                    tl = lines[j].strip()
                    m = re.match(r"tags:\s*\[([^\]]+)\]", tl)
                    if m:
                        tags = [t.strip() for t in m.group(1).split(",")]
                        break
                    if re.match(r"-\s*role:|^role:", tl):
                        break
                results.append((str(pb.relative_to(INFRA_DIR)), tags))
                break
    return results


def cmd_repo(args):
    try:
        slug = _parse_github_slug(args.url)
    except ValueError as e:
        print(f"error: {e}", file=sys.stderr)
        sys.exit(65)

    repo_name = slug.split("/")[1]
    roles_dir = INFRA_DIR / "roles"

    # Search roles/ for the full slug first, fall back to repo name alone
    matched_roles = set()
    for term in [slug, repo_name]:
        result = subprocess.run(
            ["grep", "-rl", "--include=*.yaml", term, str(roles_dir)],
            capture_output=True, text=True,
        )
        for path in result.stdout.strip().splitlines():
            parts = Path(path).relative_to(roles_dir).parts
            if parts:
                matched_roles.add(parts[0])
        if matched_roles:
            break  # slug match is specific enough; skip repo_name search

    if not matched_roles:
        print(f"No roles found referencing '{slug}'.")
        return

    print(f"Roles referencing '{slug}':\n")
    for role in sorted(matched_roles):
        playbooks = _find_playbooks_for_role(role)
        if playbooks:
            for pb_path, tags in playbooks:
                tag_str = ",".join(tags) if tags else role
                print(f"  role:     {role}")
                print(f"  playbook: {pb_path}")
                print(f"  deploy:   aw-deploy run {pb_path} --tags {tag_str}")
                print()
        else:
            print(f"  role: {role}  (no playbook includes this role)")
            print()


def main():
    parser = argparse.ArgumentParser(description="Run Ansible playbooks from the infra repo")
    sub = parser.add_subparsers(dest="command", required=True)

    p_run = sub.add_parser("run", help="Run a playbook")
    p_run.add_argument("playbook", help="Path relative to infra repo root, e.g. playbooks/hosts/apple-macmini-m4-16gb-malcolm/core.yaml")
    p_run.add_argument("--limit", help="Limit to a specific host or group")
    p_run.add_argument("--tags", help="Comma-separated Ansible tags")
    p_run.add_argument("--extra-vars", action="append", metavar="KEY=VALUE")
    p_run.add_argument("--check", action="store_true", help="Dry run (passes --check to ansible-playbook)")
    p_run.set_defaults(func=cmd_run)

    p_list = sub.add_parser("list", help="List available playbooks")
    p_list.set_defaults(func=cmd_list)

    p_hosts = sub.add_parser("hosts", help="List inventory hosts and groups")
    p_hosts.set_defaults(func=cmd_hosts)

    p_logs = sub.add_parser("logs", help="Show recent run logs")
    p_logs.add_argument("--tail", type=int, default=5, metavar="N", help="Number of recent runs to show (default: 5)")
    p_logs.set_defaults(func=cmd_logs)

    p_repo = sub.add_parser("repo", help="Find roles and playbooks that deploy a GitHub repo")
    p_repo.add_argument("url", help="GitHub repo URL (any format: HTTPS, SSH, with/without .git)")
    p_repo.set_defaults(func=cmd_repo)

    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
