# code: language=ansible
name: "{{ composition_name }}"
services:
  chives:
    container_name: "{{ composition_name }}"
    image: ghcr.io/awfulwoman/chives:latest
    restart: unless-stopped
    env_file: .environment_vars
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.{{ composition_name }}.rule=Host(`{{ composition_name }}.{{ domainname_infra }}`)"
      - "traefik.http.routers.{{ composition_name }}.tls=true"
      - "traefik.http.routers.{{ composition_name }}.tls.certresolver=letsencrypt"
      - "traefik.http.services.{{ composition_name }}.loadbalancer.server.port=8080"
    volumes:
      - "{{ composition_config }}/state:/app/state"
      - "{{ composition_config }}/profile:/app/profile"
      - "{{ composition_config }}/config.yaml:/app/config.yaml:ro"
    networks:
      - "{{ default_docker_network }}"
    healthcheck:
      test: ["CMD-SHELL", "bash -c 'echo > /dev/tcp/localhost/8080'"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s

networks:
  "{{ default_docker_network }}":
    external: true
